{
  "name": "@stellar-save/sdk",
  "version": "0.1.0",
  "description": "Shared TypeScript SDK: contract bindings, types, and API client for Stellar-Save",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "peerDependencies": {
    "@stellar/stellar-sdk": ">=14.0.0"
  },
  "devDependencies": {
    "typescript": "~5.9.3",
    "vitest": "^2.1.8"
  },
  "license": "MIT"
}
