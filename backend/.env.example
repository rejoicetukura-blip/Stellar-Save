PORT=3001

# ========== CORS ==========
# Comma-separated list of allowed frontend origins (exact match, no wildcards)
# Example: https://stellar-save.com,https://app.stellar-save.com
CORS_ALLOWED_ORIGINS=https://stellar-save.com
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
BACKUP_ENABLED=false
BACKUP_RETENTION_DAYS=30

# AWS credentials (used by services/backup.ts pg_dump → S3 upload)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
BACKUP_S3_BUCKET=stellar-save-backups
HORIZON_URL=https://horizon-testnet.stellar.org
CONTRACT_ID=CA... # Replace with actual deployed contract ID
DATABASE_URL=postgresql://user:pass@localhost:5432/stellar_save
INDEXER_ENABLED=true

# ========== JWT AUTH (#1106 refresh-token rotation) ==========
# At least 32 characters — use `openssl rand -hex 32` in production
JWT_SECRET=replace-with-a-long-random-secret-min-32-chars-in-production
# Short-lived access token TTL (e.g. 15m, 1h)
JWT_ACCESS_TOKEN_TTL=15m
# Refresh token lifetime in days
JWT_REFRESH_TOKEN_TTL_DAYS=30

# ========== PRIVACY / GDPR (#1107) ==========
# Retain PII for this many days before automatic purge (default: 365)
PII_RETENTION_DAYS=365

# ========== ON-CHAIN MONITOR (#1108) ==========
# Set to "true" to enable the on-chain anomaly monitor
ON_CHAIN_MONITOR_ENABLED=false
# Payout threshold in stroops triggering LARGE_PAYOUT alert (default 10 000 XLM)
ON_CHAIN_LARGE_PAYOUT_THRESHOLD_STROOPS=100000000000

# ========== NOTIFICATION SERVICE (Issue #557) ==========
SENDGRID_API_KEY=SG... # Your SendGrid API key
SENDGRID_FROM_EMAIL=noreply@stellar-save.com
SENDGRID_REPLY_TO=support@stellar-save.com

# Firebase Cloud Messaging (FCM)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...} # Firebase service account JSON (minified)

# OneSignal (Alternative to Firebase)
ONESIGNAL_APP_ID=your-onesignal-app-id
ONESIGNAL_API_KEY=your-onesignal-api-key

# Push notification provider selection
PUSH_PROVIDER=firebase # Options: firebase, onesignal

# ========== WEB PUSH / VAPID KEYS (Issue #push-notifications) ==========
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:noreply@stellar-save.com

# Frontend URL for unsubscribe links and redirects
FRONTEND_URL=https://stellar-save.com
APP_URL=https://stellar-save.com

# Notification processing
NOTIFICATION_QUEUE_BATCH_SIZE=100
NOTIFICATION_QUEUE_INTERVAL=60000 # Run every 60 seconds

# Email digest configuration
DIGEST_EMAIL_ENABLED=true
DIGEST_EMAIL_SCHEDULE=0 9 * * * # Daily at 9 AM (cron format)

# ========== DISTRIBUTED TRACING (OpenTelemetry → Jaeger) ==========
# Tracing is DISABLED by default. It turns on when OTEL_TRACES_ENABLED=true
# OR when an OTLP endpoint is set below. See docs/distributed-tracing.md.
OTEL_TRACES_ENABLED=false
# Service name shown in Jaeger / Grafana
OTEL_SERVICE_NAME=stellar-save-backend
# OTLP/HTTP collector base URL (OpenTelemetry Collector or Jaeger OTLP receiver).
# The /v1/traces path is appended automatically.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# Optional: override the full traces URL (takes precedence over the base above)
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
# Sampling ratio for ROOT spans (0.0–1.0). Parent decisions are always honoured
# so a sampled request stays sampled across every service. Default 0.1 (10%).
OTEL_TRACES_SAMPLER_ARG=0.1