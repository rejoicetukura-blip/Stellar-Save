PORT=3001

# ========== DATABASE ==========
DATABASE_URL=postgresql://user:pass@localhost:5432/stellar_save
# Optional read replica
# DATABASE_REPLICA_URL=postgresql://user:pass@replica-host:5432/stellar_save
# Or individual components (ECS / Secrets Manager):
# DB_USERNAME=user
# DB_PASSWORD=pass
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=stellar_save

# ========== SERVER ==========
NODE_ENV=development
ADMIN_SECRET=super-secret-admin-key

# ========== CORS ==========
# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=https://stellar-save.com

# ========== FRONTEND / APP URLS ==========
FRONTEND_URL=https://stellar-save.com
APP_URL=https://stellar-save.com

# ========== AUTH / JWT ==========
# At least 32 characters — use `openssl rand -hex 32` in production
JWT_SECRET=replace-with-a-long-random-secret-min-32-chars-in-production
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL_DAYS=30

# ========== PRIVACY / GDPR ==========
PII_RETENTION_DAYS=365

# ========== STELLAR / SOROBAN ==========
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
SOROBAN_POOL_SIZE=5
SOROBAN_POOL_TIMEOUT_MS=5000

# ========== HORIZON / CONTRACT INDEXER ==========
HORIZON_URL=https://horizon-testnet.stellar.org
CONTRACT_ID=CA... # Replace with actual deployed contract ID
INDEXER_ENABLED=false

# ========== REDIS ==========
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ========== AWS ==========
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# ========== BACKUP ==========
BACKUP_ENABLED=false
BACKUP_S3_BUCKET=stellar-save-backups
BACKUP_RETENTION_DAYS=30
# BACKUP_ALERT_WEBHOOK_URL=https://hooks.example.com/alerts

# ========== ELASTICSEARCH ==========
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=changeme

# ========== KYC ==========
KYC_PROVIDER_URL=https://sandbox.kyc-provider.example.com
KYC_WEBHOOK_SECRET=

# ========== SENDGRID ==========
SENDGRID_API_KEY=SG... # Your SendGrid API key
SENDGRID_FROM_EMAIL=noreply@stellar-save.com
SENDGRID_REPLY_TO=support@stellar-save.com

# ========== PUSH NOTIFICATIONS ==========
PUSH_PROVIDER=firebase # Options: firebase, onesignal

# Firebase Cloud Messaging
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...} # Minified JSON

# OneSignal (alternative to Firebase)
ONESIGNAL_APP_ID=your-onesignal-app-id
ONESIGNAL_API_KEY=your-onesignal-api-key

# ========== VAPID / WEB PUSH ==========
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:noreply@stellar-save.com

# ========== DISTRIBUTED TRACING (OpenTelemetry) ==========
OTEL_TRACES_ENABLED=false
OTEL_SERVICE_NAME=stellar-save-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_TRACES_SAMPLER_ARG=0.1

# ========== LOGGING ==========
LOG_LEVEL=info # debug | info | warn | error

# ========== ON-CHAIN MONITOR ==========
ON_CHAIN_MONITOR_ENABLED=false
ON_CHAIN_LARGE_PAYOUT_THRESHOLD_STROOPS=100000000000 # 10,000 XLM

# ========== FRAUD DETECTION ==========
FRAUD_DETECTION_ENABLED=true
FRAUD_SYBIL_THRESHOLD=3
FRAUD_RAPID_CYCLE_HOURS=24
FRAUD_CONTRIBUTION_OUTLIER_FACTOR=3
FRAUD_SCAN_INTERVAL_MINUTES=60

# ========== ANALYTICS RESYNC ==========
ANALYTICS_RESYNC_ENABLED=false
ANALYTICS_RESYNC_SCHEDULE=0 * * * *

# ========== CAPTCHA ==========
# CAPTCHA_SECRET_KEY=your-hcaptcha-or-turnstile-secret

# ========== KEEPER / RELAYER ==========
KEEPER_ENABLED=false
KEEPER_SCHEDULE=*/5 * * * *

# ========== TIERED RATE LIMITING ==========
RATE_LIMIT_FREE_REQ_PER_MIN=30
RATE_LIMIT_FREE_REQ_PER_HOUR=500
RATE_LIMIT_PRO_REQ_PER_MIN=300
RATE_LIMIT_PRO_REQ_PER_HOUR=10000
RATE_LIMIT_ENTERPRISE_REQ_PER_MIN=3000
RATE_LIMIT_ENTERPRISE_REQ_PER_HOUR=100000