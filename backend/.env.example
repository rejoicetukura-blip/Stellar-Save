# Stellar Save Backend - Environment Variables
# Copy this file to .env and update with your values

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Database ──────────────────────────────────────────────────────────────────
# Option 1: Direct connection URL (for local development)
DATABASE_URL=postgresql://user:pass@localhost:5432/stellar_save

# Option 2: Individual components (for ECS with Secrets Manager)
# DB_USERNAME=stellar_user
# DB_PASSWORD=<retrieved-from-secrets-manager>
# DB_HOST=stellar-save-db.cluster-xxx.us-east-1.rds.amazonaws.com
# DB_PORT=5432
# DB_NAME=stellar_save

# Read replica for analytics queries (optional)
DATABASE_REPLICA_URL=

# ── Authentication / Security ─────────────────────────────────────────────────
# IMPORTANT: In production, these should be retrieved from AWS Secrets Manager
# See backend/src/secrets_manager_service.ts for setup

# Admin API secret (CHANGE IN PRODUCTION - Use AWS Secrets Manager)
ADMIN_SECRET=super-secret-admin-key

# JWT signing secret (MUST be 32+ characters - Use AWS Secrets Manager)
JWT_SECRET=stellar-save-jwt-secret-change-in-production-min32chars
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL_DAYS=30

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for phishing protection (#1102)
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://app.stellar-save.com

# ── Stellar / Soroban ─────────────────────────────────────────────────────────
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# ── AWS Configuration ─────────────────────────────────────────────────────────
AWS_REGION=us-east-1
# For local development only - use IAM roles in production
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Secrets Manager (#1105) ───────────────────────────────────────────────────
# Enable AWS Secrets Manager integration
USE_SECRETS_MANAGER=false

# Secret names in AWS Secrets Manager
SECRET_JWT_KEY=stellar-save/jwt-secret
SECRET_ADMIN_KEY=stellar-save/admin-secret
SECRET_DB_PASSWORD=stellar-save/db-password

# ── Backup ────────────────────────────────────────────────────────────────────
BACKUP_ENABLED=false
BACKUP_S3_BUCKET=stellar-save-backups
BACKUP_RETENTION_DAYS=30
BACKUP_ALERT_WEBHOOK_URL=

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Elasticsearch ─────────────────────────────────────────────────────────────
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=changeme

# ── Privacy / GDPR ────────────────────────────────────────────────────────────
PII_RETENTION_DAYS=365

# ── KYC (Issue #1024) ─────────────────────────────────────────────────────────
KYC_PROVIDER_URL=https://sandbox.kyc-provider.example.com
KYC_WEBHOOK_SECRET=

# ── Keeper/Relayer (Issue #1026) ──────────────────────────────────────────────
KEEPER_ENABLED=false
KEEPER_SCHEDULE=*/5 * * * *

# ── Rate Limiting (Issue #1164) ───────────────────────────────────────────────
# ========== DATABASE ==========
DATABASE_URL=postgresql://user:pass@localhost:5432/stellar_save
# Optional read replica
# DATABASE_REPLICA_URL=postgresql://user:pass@replica-host:5432/stellar_save
# Or individual components (ECS / Secrets Manager):
# DB_USERNAME=user
# DB_PASSWORD=pass
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=stellar_save

# ========== SERVER ==========
NODE_ENV=development
ADMIN_SECRET=super-secret-admin-key

# ========== CORS ==========
# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=https://stellar-save.com

# ========== FRONTEND / APP URLS ==========
FRONTEND_URL=https://stellar-save.com
APP_URL=https://stellar-save.com

# ========== AUTH / JWT ==========
# At least 32 characters — use `openssl rand -hex 32` in production
JWT_SECRET=replace-with-a-long-random-secret-min-32-chars-in-production
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL_DAYS=30

# ========== PRIVACY / GDPR ==========
PII_RETENTION_DAYS=365

# ========== STELLAR / SOROBAN ==========
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
SOROBAN_POOL_SIZE=5
SOROBAN_POOL_TIMEOUT_MS=5000

# ========== HORIZON / CONTRACT INDEXER ==========
HORIZON_URL=https://horizon-testnet.stellar.org
CONTRACT_ID=CA... # Replace with actual deployed contract ID
INDEXER_ENABLED=false

# ========== REDIS ==========
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ========== AWS ==========
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# ========== BACKUP ==========
BACKUP_ENABLED=false
BACKUP_S3_BUCKET=stellar-save-backups
BACKUP_RETENTION_DAYS=30
# BACKUP_ALERT_WEBHOOK_URL=https://hooks.example.com/alerts

# ========== ELASTICSEARCH ==========
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=changeme

# ========== KYC ==========
KYC_PROVIDER_URL=https://sandbox.kyc-provider.example.com
KYC_WEBHOOK_SECRET=

# ========== SENDGRID ==========
SENDGRID_API_KEY=SG... # Your SendGrid API key
SENDGRID_FROM_EMAIL=noreply@stellar-save.com
SENDGRID_REPLY_TO=support@stellar-save.com

# ========== PUSH NOTIFICATIONS ==========
PUSH_PROVIDER=firebase # Options: firebase, onesignal

# Firebase Cloud Messaging
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...} # Minified JSON

# OneSignal (alternative to Firebase)
ONESIGNAL_APP_ID=your-onesignal-app-id
ONESIGNAL_API_KEY=your-onesignal-api-key

# ========== VAPID / WEB PUSH ==========
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:noreply@stellar-save.com

# ========== DISTRIBUTED TRACING (OpenTelemetry) ==========
OTEL_TRACES_ENABLED=false
OTEL_SERVICE_NAME=stellar-save-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_TRACES_SAMPLER_ARG=0.1

# ========== LOGGING ==========
LOG_LEVEL=info # debug | info | warn | error

# ========== ON-CHAIN MONITOR ==========
ON_CHAIN_MONITOR_ENABLED=false
ON_CHAIN_LARGE_PAYOUT_THRESHOLD_STROOPS=100000000000 # 10,000 XLM

# ========== FRAUD DETECTION ==========
FRAUD_DETECTION_ENABLED=true
FRAUD_SYBIL_THRESHOLD=3
FRAUD_RAPID_CYCLE_HOURS=24
FRAUD_CONTRIBUTION_OUTLIER_FACTOR=3
FRAUD_SCAN_INTERVAL_MINUTES=60

# ========== ANALYTICS RESYNC ==========
ANALYTICS_RESYNC_ENABLED=false
ANALYTICS_RESYNC_SCHEDULE=0 * * * *

# ========== CAPTCHA ==========
# CAPTCHA_SECRET_KEY=your-hcaptcha-or-turnstile-secret

# ========== KEEPER / RELAYER ==========
KEEPER_ENABLED=false
KEEPER_SCHEDULE=*/5 * * * *

# ========== TIERED RATE LIMITING ==========
RATE_LIMIT_FREE_REQ_PER_MIN=30
RATE_LIMIT_FREE_REQ_PER_HOUR=500
RATE_LIMIT_PRO_REQ_PER_MIN=300
RATE_LIMIT_PRO_REQ_PER_HOUR=10000
RATE_LIMIT_ENTERPRISE_REQ_PER_MIN=3000
RATE_LIMIT_ENTERPRISE_REQ_PER_HOUR=100000

# ── Security (#1103) ──────────────────────────────────────────────────────────
# Input sanitization settings
SANITIZATION_MAX_LENGTH=5000
SANITIZATION_STRICT_MODE=true

# CSP configuration
CSP_REPORT_URI=
CSP_REPORT_ONLY=false

# ── Penetration Testing (#1104) ───────────────────────────────────────────────
# OWASP ZAP configuration (used in CI/CD)
ZAP_ENABLED=false
ZAP_TARGET_URL=http://localhost:3001
ZAP_API_KEY=

# Severity thresholds for CI/CD gating
ZAP_HIGH_SEVERITY_THRESHOLD=0
ZAP_MEDIUM_SEVERITY_THRESHOLD=5

# ── Fraud Detection ───────────────────────────────────────────────────────────
FRAUD_SYBIL_THRESHOLD=3
FRAUD_RAPID_CYCLE_HOURS=24
FRAUD_CONTRIBUTION_OUTLIER_FACTOR=3

# ── Monitoring & Observability ───────────────────────────────────────────────
# OpenTelemetry
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# ── External Services ─────────────────────────────────────────────────────────
# SendGrid (email)
SENDGRID_API_KEY=

# Firebase (push notifications)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ── IPFS ───────────────────────────────────────────────────────────────────────
IPFS_ENABLED=false
IPFS_API_URL=http://localhost:5001
IPFS_API_TIMEOUT_MS=30000
IPFS_GATEWAY_URL=http://localhost:8080
IPFS_PIN_RETRY_COUNT=3
IPFS_PIN_CHECK_INTERVAL_MS=5000
IPFS_MONITOR_INTERVAL_MS=60000

# ── Development ───────────────────────────────────────────────────────────────
# Enable debug logging
DEBUG=false

# Mock external services
MOCK_STELLAR=false
MOCK_KYC=false
