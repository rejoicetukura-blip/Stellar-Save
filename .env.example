# ── Server ────────────────────────────────────────────────────────────────────
# Runtime environment: development | test | production
NODE_ENV=development

# Port the backend API server listens on
PORT=3001

# ── Admin ─────────────────────────────────────────────────────────────────────
# Secret used to authenticate admin API requests (x-admin-secret header)
# Required in production — change this to a strong random value
ADMIN_SECRET=super-secret-admin-key

# ── Auth / JWT (#1106) ────────────────────────────────────────────────────────
# HMAC-SHA256 secret for signing JWTs — must be at least 32 characters
# Required in production — use `openssl rand -hex 32` to generate
JWT_SECRET=stellar-save-jwt-secret-change-in-production-min32chars

# Lifetime of short-lived access tokens (e.g. 15m, 1h)
JWT_ACCESS_TOKEN_TTL=15m

# Lifetime of refresh tokens in days (default: 30)
JWT_REFRESH_TOKEN_TTL_DAYS=30

# ── Privacy / GDPR (#1107) ────────────────────────────────────────────────────
# Days to retain PII before automatic purge (default: 365)
PII_RETENTION_DAYS=365

# ── On-Chain Monitor (#1108) ──────────────────────────────────────────────────
# Set to "true" to enable the on-chain anomaly monitor
ON_CHAIN_MONITOR_ENABLED=false

# Payout amount in stroops (1 XLM = 10_000_000 stroops) that triggers LARGE_PAYOUT alert
# Default: 100_000_000_000 = 10 000 XLM
ON_CHAIN_LARGE_PAYOUT_THRESHOLD_STROOPS=100000000000

# ── Stellar / Soroban ─────────────────────────────────────────────────────────
# Network to connect to: testnet | mainnet | futurenet | standalone
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# Contract addresses (populated after deployment)
CONTRACT_GUESS_THE_NUMBER=
CONTRACT_FUNGIBLE_ALLOWLIST=
CONTRACT_NFT_ENUMERABLE=

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# These are exposed to the browser — do NOT put secrets here
VITE_STELLAR_NETWORK=testnet
VITE_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
VITE_CONTRACT_GUESS_THE_NUMBER=
VITE_CONTRACT_FUNGIBLE_ALLOWLIST=
VITE_CONTRACT_NFT_ENUMERABLE=

# ── Distributed tracing (OpenTelemetry web → Jaeger) ──────────────────────────
# Disabled by default. See docs/distributed-tracing.md.
VITE_OTEL_ENABLED=false
# OTLP/HTTP collector base URL (the /v1/traces path is appended automatically)
VITE_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
VITE_OTEL_SERVICE_NAME=stellar-save-frontend
# Root-span sample ratio (0.0–1.0). Default 0.1 (10%).
VITE_OTEL_TRACES_SAMPLER_ARG=0.1
# CSV of URL prefixes that should receive the W3C traceparent header
VITE_OTEL_PROPAGATE_URLS=/api,http://localhost:3001

# ── Backup ────────────────────────────────────────────────────────────────────
# Set to "true" to enable the automated backup scheduler and monitor
BACKUP_ENABLED=false

# S3 bucket name for storing backups
BACKUP_S3_BUCKET=stellar-save-backups

# How many days to retain backups before pruning (default: 30)
BACKUP_RETENTION_DAYS=30

# Optional webhook URL to receive backup alert notifications (POST JSON)
BACKUP_ALERT_WEBHOOK_URL=

# ── AWS ───────────────────────────────────────────────────────────────────────
# Required when BACKUP_ENABLED=true
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Elasticsearch ─────────────────────────────────────────────────────────────
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=changeme
